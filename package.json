    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "motion-v": "^2.3.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.10.1",
    "shadcn-vue": "^2.7.4",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.27",
    "vue-router": "^5.0.1",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
